#!/usr/bin/env python3
"""
python3 matrix_effects.py
"""

import os
import sys
import time
import random
import subprocess
from pathlib import Path

# COLORS
RESET = "\u001B[0m"
GREEN = "\u001B[92m"
RED = "\u001B[91m"
YELLOW = "\u001B[93m"
CYAN = "\u001B[96m"
BLUE = "\u001B[94m"
MAGENTA = "\u001B[95m"

class MatrixRON:
    def __init__(self):
        self.home = Path("/root/R.O.N")
        self.home.mkdir(exist_ok=True)
    
    def clear(self):
        os.system('clear')
    
    def matrix_intro(self):
        """Matrix rain startup"""
        self.clear()
        print(f"{CYAN}╔{'═' * 78}╗{RESET}")
        print(f"{CYAN}║{GREEN}              MATRIX PENTEST INTERFACE ACTIVE              {CYAN}║{RESET}")
        print(f"{CYAN}╚{'═' * 78}╝{RESET}
")
        
        chars = "01ハカイHACK10カイ01"
        for _ in range(8):
            line = ''.join(random.choice(chars) for _ in range(80))
            print(f"{GREEN}{line[:78]}{RESET}")
            time.sleep(0.15)
            self.clear()
    
    def loading_bar(self, text="TOR Loading"):
        """Smooth loading bar"""
        for i in range(101):
            bar = f"{BLUE}█{RESET}" * (i//10) + f"{YELLOW}░{RESET}" * (10-i//10)
            percent = f"{GREEN}{i:3d}%{RESET}"
            print(f"
{CYAN}[{bar}] {text} {percent}{RESET}", end='')
            sys.stdout.flush()
            time.sleep(0.03)
        print()
    
    def task_success(self, task_name):
        """Task complete effect"""
        print(f"
{GREEN}{'█' * 80}{RESET}")
        print(f"{YELLOW}🎯 {task_name.upper()} COMPLETE - SUCCESS{RESET}")
        print(f"{GREEN}{'█' * 80}{RESET}")
        for i in range(5):
            stars = f"{MAGENTA}✦{RESET}" * ((i+1)*3)
            print(f"{stars} MISSION ACCOMPLISHED {stars}")
            time.sleep(0.2)
    
    def password_found(self):
        """Password animation"""
        print(f"
{RED}{'🔓' * 40}{RESET}")
        print(f"{YELLOW}PASSWORD CRACKED! ACCESS GRANTED{RESET}")
        print(f"{RED}{'🔓' * 40}{RESET}")
        password = "p@ssw0rd123!🔓"
        for i, char in enumerate(password):
            print(f"
{YELLOW}{password[:i+1]}{RESET}", end='')
            time.sleep(0.15)
        print(f"
{GREEN}💾 SAVED TO DATABASE{RESET}")
    
    def scan_radar(self):
        """Scan complete radar"""
        print(f"
{CYAN}{'█' * 80}{RESET}")
        print(f"{GREEN}NETWORK MAPPED - SCAN COMPLETE{RESET}")
        for i in range(24):
            radar = f"{BLUE}{'█' * i}{'░' * (23-i)}{RESET}"
            print(f"
{GREEN}[RADAR]{radar} {i*4.5:.0f}%{RESET}", end='')
            time.sleep(0.08)
    
    def run_ron_with_effects(self):
        """Run ron.py with effects wrapper"""
        self.matrix_intro()
        self.loading_bar("TOR Network")
        self.loading_bar("Knowledge Base")
        
        print(f"
{GREEN}🎯 R.O.N SYSTEMS ONLINE{RESET}")
        print(f"{CYAN}{'═' * 80}{RESET}")
        
        # Launch main ron.py
        os.chdir(self.home)
        os.execlp("python3", "python3", "ron.py")

def main():
    MatrixRON().run_ron_with_effects()

if __name__ == "__main__":
    main()
